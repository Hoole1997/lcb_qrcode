<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- 顶部渐变背景 -->
    <View
        android:id="@+id/topGradient"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="@drawable/qrcode_bg_scan_result_top"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 返回按钮 -->
    <FrameLayout
        android:id="@+id/ivBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="44dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@string/qrcode_action_back"
            android:src="@drawable/ic_arrow_back"
            android:tint="#333333" />

    </FrameLayout>

    <!-- 标题 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="55dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/qrcode_result_title"
        android:textColor="#333333"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 收藏按钮 -->
    <ImageView
        android:id="@+id/ivFavorite"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@string/qrcode_action_favorite"
        android:src="@drawable/qrcode_ic_favorite_outline"
        app:layout_constraintBottom_toBottomOf="@id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTitle" />

    <!-- 更多按钮 -->
    <ImageView
        android:id="@+id/ivMore"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        android:contentDescription="@string/qrcode_action_more"
        android:src="@drawable/qrcode_ic_more_vert"
        app:layout_constraintBottom_toBottomOf="@id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTitle" />

    <!-- 二维码类型图标背景 -->
    <View
        android:id="@+id/iconBg"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/qrcode_bg_scan_type_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topGradient" />

    <!-- 二维码类型图标 -->
    <ImageView
        android:id="@+id/ivTypeIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@string/qrcode_result_type"
        android:src="@drawable/qrcode_ic_link"
        app:layout_constraintBottom_toBottomOf="@id/iconBg"
        app:layout_constraintEnd_toEndOf="@id/iconBg"
        app:layout_constraintStart_toStartOf="@id/iconBg"
        app:layout_constraintTop_toTopOf="@id/iconBg" />

    <!-- 二维码类型 -->
    <TextView
        android:id="@+id/tvType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:fontFamily="sans-serif-medium"
        android:text="QR_CODE"
        android:textColor="#666666"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/iconBg"
        app:layout_constraintStart_toEndOf="@id/iconBg"
        app:layout_constraintTop_toTopOf="@id/iconBg" />

    <!-- 扫描时间 -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:text="19 November 2025 | 04:51 PM"
        android:textColor="#999999"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/iconBg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/iconBg" />

    <!-- 内容卡片 -->
    <FrameLayout
        android:id="@+id/cardContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_qrcode_result_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconBg">

        <TextView
            android:id="@+id/tvContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="6dp"
            android:minHeight="150dp"
            android:padding="14dp"
            android:text="Scan result content"
            android:textColor="#666666"
            android:textSize="14sp" />

    </FrameLayout>

    <!-- View QR 和 Share 按钮容器 -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardContent">

        <!-- View QR 按钮 -->
        <LinearLayout
            android:id="@+id/btnViewQR"
            android:layout_width="160dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_qrcode_result_button"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/qrcode_result_view_qr"
                android:src="@drawable/qrcode_ic_qr_code"
                app:tint="#333333" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/qrcode_result_view_qr"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Share 按钮 -->
        <LinearLayout
            android:id="@+id/btnShare"
            android:layout_width="160dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_qrcode_result_button"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/qrcode_result_share"
                android:src="@drawable/qrcode_ic_share"
                app:tint="#333333" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/qrcode_result_share"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Search Web 按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSearchWeb"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#2B85FF"
        android:text="@string/qrcode_result_search_web"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="10dp"
        app:icon="@drawable/qrcode_ic_search"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonContainer"
        app:strokeColor="#A4CBFF"
        app:strokeWidth="1dp" />

    <FrameLayout
        android:id="@+id/ad_Container"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</androidx.constraintlayout.widget.ConstraintLayout>
