<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 上方扫光渐变效果 -->
    <item android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00F7BD29"
                android:endColor="#66F7BD29"
                android:angle="270" />
        </shape>
    </item>
    <!-- 底部6dp红色实线 -->
    <item android:gravity="bottom" android:height="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/qrcode_primary" />
        </shape>
    </item>
</layer-list>
